# --- Server ---
NODE_ENV=development
PORT=4000

# Comma-separated allowed origins, or * for all (development only)
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
# Local: postgresql://USER:PASSWORD@localhost:5432/ims?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ims?schema=public

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
